# ── AI ────────────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email (Gmail example) ─────────────────────────────────────────────────────
# Use an App Password (not your main password): myaccount.google.com/apppasswords
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_TO=you@gmail.com

# ── Schedule ──────────────────────────────────────────────────────────────────
# Times in UTC (24h format)
BRIEFING_TIME=07:30
SCANNER_TIME=08:00

# Run scanner every N minutes (overrides SCANNER_TIME if set)
# e.g. SCANNER_INTERVAL_MIN=15 → scans every 15 minutes
# Leave blank to use the daily SCANNER_TIME instead
SCANNER_INTERVAL_MIN=

# ── Delivery channels ─────────────────────────────────────────────────────────
# Comma-separated: terminal, telegram, email, desktop
DELIVERY_CHANNELS=terminal,telegram,email,desktop

# ── Scanner timeframe range ───────────────────────────────────────────────────
# Scans every minute-based TF from MIN to MAX (inclusive)
# 1440 = 1 Day. Scanning 30→1440 = 1411 timeframes
SCANNER_TF_MIN=30
SCANNER_TF_MAX=1440

# ── Scanner patterns ──────────────────────────────────────────────────────────
# Comma-separated list of patterns to scan for.
# Available: 4-Flag, Morning Star, Evening Star
# Remove any you don't want — e.g. only flag: SCANNER_PATTERNS=4-Flag
SCANNER_PATTERNS=4-Flag,Morning Star,Evening Star
